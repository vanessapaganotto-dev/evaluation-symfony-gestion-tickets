{% extends 'base.html.twig' %}

{% block title %}Liste des tickets{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Liste des tickets</h1>
    
    <a href="{{ path('ticket_new') }}" class="btn btn-primary mb-3">
        + Nouveau ticket
    </a>
    
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Description</th>
                <th>Catégorie</th>
                <th>Date d'ouverture</th>
                <th>État</th>
            </tr>
        </thead>
        <tbody>
            {% for ticket in tickets %}
            <tr>
                <td>{{ ticket.id }}</td>
                <td>{{ ticket.auteur }}</td>
                <td>{{ ticket.description|slice(0, 50) }}...</td>
                <td>{{ ticket.categorie ? ticket.categorie.nom : '-' }}</td>
                <td>{{ ticket.dateOuverture|date('d/m/Y H:i') }}</td>
                <td>
                    <span class="badge bg-info">
                        {{ ticket.etat ? ticket.etat.nom : 'Nouveau' }}
                    </span>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="text-center">Aucun ticket trouvé</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}