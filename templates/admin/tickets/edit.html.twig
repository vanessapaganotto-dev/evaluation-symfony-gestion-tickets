{% extends 'base.html.twig' %}

{% block title %}Modifier le ticket{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1 class="mb-4">Modifier le ticket #{{ ticket.id }}</h1>

    {# Flash messages (interaction utilisateur) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Formulaire #}
    {{ include('admin/tickets/_form.html.twig', {
        button_label: 'Modifier'
    }) }}

    <div class="mt-3 d-flex gap-2">
        <a href="{{ path('admin_tickets_index') }}" class="btn btn-secondary">
            Retour à la liste
        </a>

        <a href="{{ path('admin_tickets_show', {'id': ticket.id}) }}" class="btn btn-info">
            Voir le ticket
        </a>
    </div>

</div>
{% endblock %}