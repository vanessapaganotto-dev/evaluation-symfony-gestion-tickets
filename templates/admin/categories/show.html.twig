{% extends 'base.html.twig' %}

{% block title %}Détails de la catégorie{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Détails de la catégorie</h1>
    
    <table class="table">
        <tr>
            <th>ID</th>
            <td>{{ categorie.id }}</td>
        </tr>
        <tr>
            <th>Nom</th>
            <td>{{ categorie.nom }}</td>
        </tr>
    </table>
    
    <a href="{{ path('admin_categories_index') }}" class="btn btn-secondary">Retour à la liste</a>
</div>
{% endblock %}